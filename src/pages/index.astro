---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const dogs = await getCollection('dogs');
const currentDog = dogs.find((dog) => dog.data.current) ?? dogs[0];
const { title, status, rescue, location, age, sex, breed, weight, heroImage, applyUrl, bio, traits, quickFacts, idealHome, story } = currentDog.data;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | {rescue}</title>
		<meta name="description" content={bio} />
	</head>
	<body class="bg-bg text-text font-body antialiased">
		<div class="max-w-[1400px] mx-auto px-6 md:px-12">
			<nav class="py-7">
				<div class="font-heading font-bold text-xl">
					Must Luv <span class="text-pink">Boxers</span> Rescue
				</div>
			</nav>

			<div class="flex flex-col md:flex-row items-center gap-10 md:gap-16 py-6 md:py-16">
				<div class="flex-none md:basis-[40%] w-full">
					<div class="inline-flex items-center gap-2 bg-pink-light text-[#C9748F] px-4.5 py-2 rounded-full text-sm font-semibold mb-5">
						♥ {status}
					</div>
					<h1 class="font-heading font-bold text-5xl md:text-6xl leading-none mb-5">{title}</h1>
					<p class="text-text-muted text-base mb-8">{location} &middot; Fostered with {rescue}</p>

					<div class="flex flex-wrap gap-6 mb-9">
						<div>
							<div class="text-xl mb-1.5">🐶</div>
							<div class="font-semibold">{age}</div>
							<div class="text-text-muted text-xs">Age</div>
						</div>
						<div>
							<div class="text-xl mb-1.5">🐾</div>
							<div class="font-semibold">{breed}</div>
							<div class="text-text-muted text-xs">Breed</div>
						</div>
						<div>
							<div class="text-xl mb-1.5">♀</div>
							<div class="font-semibold">{sex}</div>
							<div class="text-text-muted text-xs">Sex</div>
						</div>
						<div>
							<div class="text-xl mb-1.5">⚖️</div>
							<div class="font-semibold">{weight}</div>
							<div class="text-text-muted text-xs">Weight</div>
						</div>
					</div>

					<a
						href={applyUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2.5 bg-pink text-white font-semibold px-8 py-4 rounded-full shadow-[0_8px_24px_rgba(246,182,200,0.45)] transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(246,182,200,0.55)]"
					>
						Apply to Meet {title} 🐾
					</a>
				</div>

				<div class="flex-none md:basis-[56%] w-full md:ml-auto">
					<img
						src={`${base}${heroImage}`}
						alt={`${title}, a ${breed.toLowerCase()}, resting`}
						class="w-full h-[360px] md:h-[560px] object-cover rounded-3xl shadow-[0_24px_60px_rgba(62,58,57,0.15)] transition-transform duration-500 hover:scale-[1.015]"
					/>
				</div>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 pb-16 md:pb-24">
				<div class="bg-pink-light rounded-[22px] p-7">
					<h3 class="font-heading font-semibold text-lg mb-4">About Me ♡</h3>
					<p class="text-text-muted text-sm">{bio}</p>
				</div>
				<div class="bg-pink-light rounded-[22px] p-7">
					<h3 class="font-heading font-semibold text-lg mb-4">I'm... ♡</h3>
					<ul class="flex flex-col gap-2.5 text-sm">
						{traits.map((trait) => <li>♡ {trait}</li>)}
					</ul>
				</div>
				<div class="bg-pink-light rounded-[22px] p-7">
					<h3 class="font-heading font-semibold text-lg mb-4">Quick Facts ♡</h3>
					<ul class="flex flex-col gap-2.5 text-sm">
						{quickFacts.map((fact) => <li>{fact}</li>)}
					</ul>
				</div>
				<div class="bg-pink-light rounded-[22px] p-7">
					<h3 class="font-heading font-semibold text-lg mb-4">At a Glance ♡</h3>
					<ul class="flex flex-col gap-2.5 text-sm">
						<li>❤️ Spayed</li>
						<li>🤫 Rarely vocalizes</li>
						<li>🛏️ Sleeps quietly</li>
						<li>🐢 Building leash confidence</li>
					</ul>
				</div>
			</div>
		</div>

		<section class="bg-cream">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-5">Her Story</h2>
				<p class="text-text-muted text-base md:text-lg max-w-3xl">{story}</p>
			</div>
		</section>

		<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
			<h2 class="font-heading font-bold text-3xl md:text-4xl text-center mb-10">Her Ideal Home</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
				{idealHome.map((item) => (
					<div class="bg-pink-accent rounded-[20px] p-7 text-center font-medium transition-transform hover:-translate-y-1">
						<span class="block text-[#4E8B6A] text-xl mb-2.5">✓</span>
						{item}
					</div>
				))}
			</div>
		</div>

		<div class="mx-6 md:mx-12 mb-16 md:mb-24 rounded-[28px] bg-gradient-to-br from-pink-accent to-pink-light px-6 md:px-12 py-14 md:py-18 text-center">
			<h2 class="font-heading font-bold text-3xl md:text-4xl mb-3">Could {title} be your next family member?</h2>
			<p class="text-text-muted text-base md:text-lg mb-8">Fill out an adoption application and the {rescue} team will follow up with next steps.</p>
			<a
				href={applyUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2.5 bg-pink text-white font-semibold px-8 py-4 rounded-full shadow-[0_8px_24px_rgba(246,182,200,0.45)] transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(246,182,200,0.55)]"
			>
				Start {title}'s Application 🐾
			</a>
		</div>

		<footer class="text-center text-text-muted text-sm pb-16">
			<div class="font-heading text-text text-lg mb-2">{rescue}</div>
			<div>Serving WA, OR &amp; Northern ID</div>
			<div class="font-accent text-2xl text-[#C9748F] mt-4">Thank you for helping rescue dogs find loving homes.</div>
		</footer>
	</body>
</html>
