---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const dogs = await getCollection('dogs');
const currentDog = dogs.find((dog) => dog.data.current) ?? dogs[0];
const {
	title, status, rescue, location, age, sex, breed, weight, heroImage, applyUrl,
	story, firstThing, dayInLife, personality, confidence,
	aroundHouseIntro, aroundHouseList, walking, otherDogs, children,
	food, health, carRides, grooming, loves, quirks,
	stillWorking, lookingFor, finalThoughts,
} = currentDog.data;

const comingSoon = [
	{ icon: '📸', title: 'Gallery' },
	{ icon: '📔', title: 'Foster Journal' },
];
const base = import.meta.env.BASE_URL;
const rescueFacebookUrl = 'https://www.facebook.com/Mustluvboxersrescue';
const rescueWebsiteUrl = 'https://www.mustluvboxersrescue.com/';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | {rescue}</title>
		<meta name="description" content={story} />
	</head>
	<body class="bg-bg text-text font-body antialiased">
		<div class="max-w-[1400px] mx-auto px-6 md:px-12">
			<nav class="py-7">
				<a
					href={rescueFacebookUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="font-heading font-bold text-xl hover:opacity-80 transition-opacity"
				>
					MustLuv<span class="text-pink">Boxers</span> Rescue
				</a>
			</nav>

			<div class="flex flex-col md:flex-row items-center gap-10 md:gap-16 py-6 md:py-16">
				<div class="flex-none md:basis-[40%] w-full">
					<div class="inline-flex items-center gap-2 bg-pink-light text-[#C9748F] px-4.5 py-2 rounded-full text-sm font-semibold mb-5">
						♥ {status}
					</div>
					<h1 class="font-heading font-bold text-5xl md:text-6xl leading-none mb-5">{title}</h1>
					<p class="text-text-muted text-base mb-8">{location} &middot; Fostered with {rescue}</p>

					<div class="flex flex-wrap gap-6 mb-9">
						<div>
							<div class="text-xl mb-1.5">🐶</div>
							<div class="font-semibold">{age}</div>
							<div class="text-text-muted text-xs">Age</div>
						</div>
						<div>
							<div class="text-xl mb-1.5">🐾</div>
							<div class="font-semibold">{breed}</div>
							<div class="text-text-muted text-xs">Breed</div>
						</div>
						<div>
							<div class="text-xl mb-1.5">♀</div>
							<div class="font-semibold">{sex}</div>
							<div class="text-text-muted text-xs">Sex</div>
						</div>
						<div>
							<div class="text-xl mb-1.5">⚖️</div>
							<div class="font-semibold">{weight}</div>
							<div class="text-text-muted text-xs">Weight</div>
						</div>
					</div>

					<a
						href={applyUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2.5 bg-pink text-white font-semibold px-8 py-4 rounded-full shadow-[0_8px_24px_rgba(246,182,200,0.45)] transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(246,182,200,0.55)]"
					>
						Apply to Meet {title} 🐾
					</a>
				</div>

				<div class="flex-none md:basis-[56%] w-full md:ml-auto">
					<img
						src={`${base}${heroImage}`}
						alt={`Photos of ${title}, a ${breed.toLowerCase()}, at home and out on walks`}
						class="w-full h-auto object-contain rounded-3xl shadow-[0_24px_60px_rgba(62,58,57,0.15)] transition-transform duration-500 hover:scale-[1.015]"
					/>
				</div>
			</div>
		</div>

		<!-- Abby's Story -->
		<section class="bg-cream">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-5">Abby's Story</h2>
				<p class="text-text-muted text-base md:text-lg max-w-3xl">{story}</p>
			</div>
		</section>

		<!-- The First Thing You Should Know -->
		<section>
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
				<span class="text-3xl">♡</span>
				<h2 class="font-heading font-bold text-3xl md:text-4xl mt-4 mb-6">The First Thing You Should Know</h2>
				<p class="text-text text-lg md:text-xl leading-relaxed">{firstThing}</p>
			</div>
		</section>

		<!-- A Day in Abby's Life -->
		<section class="bg-cream">
			<div class="max-w-[800px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl text-center mb-3">A Day in Abby's Life</h2>
				<p class="text-text-muted text-center mb-12">What a fairly typical Tuesday looks like</p>
				<div class="flex flex-col gap-6">
					{dayInLife.map((moment) => (
						<div class="flex gap-5 items-baseline">
							<div class="flex-none w-24 text-right font-heading font-semibold text-pink">{moment.time}</div>
							<div class="flex-none w-2 h-2 rounded-full bg-pink mt-1.5"></div>
							<p class="text-text-muted text-sm md:text-base flex-1">{moment.activity}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Personality -->
		<section>
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-6">Personality</h2>
				<p class="text-text-muted text-lg leading-relaxed">{personality}</p>
			</div>
		</section>

		<!-- Confidence -->
		<section class="bg-cream">
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-6">Finding Her Confidence</h2>
				<p class="text-text-muted text-lg leading-relaxed">{confidence}</p>
			</div>
		</section>

		<!-- Around the House -->
		<section>
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-6">Around the House</h2>
				<p class="text-text-muted text-lg leading-relaxed mb-8">{aroundHouseIntro}</p>
				<ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
					{aroundHouseList.map((item) => (
						<li class="text-text-muted">♡ {item}</li>
					))}
				</ul>
			</div>
		</section>

		<!-- Walking -->
		<section class="bg-cream">
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-6">On Walks</h2>
				<p class="text-text-muted text-lg leading-relaxed">{walking}</p>
			</div>
		</section>

		<!-- Other Dogs & Children -->
		<section>
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl text-center mb-10">Meeting New Friends</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
					<div>
						<h3 class="font-heading font-semibold text-xl mb-3">🐕 Other Dogs</h3>
						<p class="text-text-muted leading-relaxed">{otherDogs}</p>
					</div>
					<div>
						<h3 class="font-heading font-semibold text-xl mb-3">🧒 Children</h3>
						<p class="text-text-muted leading-relaxed">{children}</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Practical Notes -->
		<section class="bg-cream">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl text-center mb-10">A Few Practical Notes</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-pink-light rounded-[22px] p-7">
						<h3 class="font-heading font-semibold text-lg mb-3">🍽️ Food</h3>
						<p class="text-text-muted text-sm">{food}</p>
					</div>
					<div class="bg-pink-light rounded-[22px] p-7">
						<h3 class="font-heading font-semibold text-lg mb-3">🩺 Health</h3>
						<p class="text-text-muted text-sm">{health}</p>
					</div>
					<div class="bg-pink-light rounded-[22px] p-7">
						<h3 class="font-heading font-semibold text-lg mb-3">🚗 Car Rides</h3>
						<p class="text-text-muted text-sm">{carRides}</p>
					</div>
					<div class="bg-pink-light rounded-[22px] p-7">
						<h3 class="font-heading font-semibold text-lg mb-3">🛁 Grooming</h3>
						<p class="text-text-muted text-sm">{grooming}</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Loves & Quirks -->
		<section>
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto">
					<div>
						<h2 class="font-heading font-bold text-2xl md:text-3xl mb-5">Things Abby Loves</h2>
						<ul class="flex flex-col gap-2.5">
							{loves.map((item) => <li class="text-text-muted">♡ {item}</li>)}
						</ul>
					</div>
					<div>
						<h2 class="font-heading font-bold text-2xl md:text-3xl mb-5">Her Little Quirks</h2>
						<ul class="flex flex-col gap-2.5">
							{quirks.map((item) => <li class="text-text-muted">🐾 {item}</li>)}
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Still Working On -->
		<section class="bg-cream">
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-6">Still Growing</h2>
				<p class="text-text-muted text-lg leading-relaxed">{stillWorking}</p>
			</div>
		</section>

		<!-- Who She's Looking For -->
		<section>
			<div class="max-w-[1000px] mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-6">Who She's Looking For</h2>
				<p class="text-text-muted text-lg leading-relaxed">{lookingFor}</p>
			</div>
		</section>

		<!-- Final Thoughts + CTA -->
		<div class="max-w-[1400px] mx-auto px-6 md:px-12">
			<div class="rounded-[28px] bg-gradient-to-br from-pink-accent to-pink-light px-6 md:px-12 py-14 md:py-20 text-center mb-16 md:mb-24">
				<p class="text-text text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10">{finalThoughts}</p>
				<h2 class="font-heading font-bold text-3xl md:text-4xl mb-3">Could {title} be your next family member?</h2>
				<p class="text-text-muted text-base md:text-lg mb-8">Fill out an adoption application and the {rescue} team will follow up with next steps.</p>
				<a
					href={applyUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2.5 bg-pink text-white font-semibold px-8 py-4 rounded-full shadow-[0_8px_24px_rgba(246,182,200,0.45)] transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(246,182,200,0.55)]"
				>
					Start {title}'s Application 🐾
				</a>
			</div>
		</div>

		<!-- Coming Soon -->
		<section class="bg-cream">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 py-16 md:py-24">
				<h2 class="font-heading font-bold text-3xl md:text-4xl text-center mb-3">More About Abby</h2>
				<p class="text-text-muted text-center mb-10">We're still building out her full profile &mdash; check back soon.</p>
				<div class="grid grid-cols-2 gap-5 max-w-md mx-auto">
					{comingSoon.map((item) => (
						<div class="rounded-[20px] border border-dashed border-pink p-7 text-center">
							<span class="block text-2xl mb-3 opacity-60">{item.icon}</span>
							<h3 class="font-heading font-semibold mb-1">{item.title}</h3>
							<p class="text-text-muted text-xs">Coming soon</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<footer class="text-center text-text-muted text-sm pb-16 pt-16">
			<div class="font-heading text-text text-lg mb-2">{rescue}</div>
			<div>Serving WA, OR &amp; Northern ID</div>

			<div class="flex items-center justify-center gap-4 mt-6">
				<a
					href={rescueFacebookUrl}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`${rescue} on Facebook`}
					class="flex items-center justify-center w-11 h-11 rounded-full bg-pink-light text-[#C9748F] shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
						<path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.89h2.78l-.45 2.91h-2.33V22c4.78-.76 8.44-4.92 8.44-9.94Z"/>
					</svg>
				</a>
				<a
					href={rescueWebsiteUrl}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`${rescue} website`}
					class="flex items-center justify-center w-11 h-11 rounded-full bg-pink-light text-[#C9748F] shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
						<circle cx="12" cy="12" r="9" />
						<path d="M3 12h18" />
						<path d="M12 3c2.5 2.5 3.8 5.8 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.8-3.8-9s1.3-6.5 3.8-9Z" />
					</svg>
				</a>
			</div>

			<div class="font-accent text-2xl text-[#C9748F] mt-6">Thank you for helping rescue dogs find loving homes.</div>
		</footer>
	</body>
</html>
